<?xml version="1.0" encoding="UTF-8"?>
<ui version="4.0">
 <class>YOLOModDialogBase</class>
 <widget class="QDialog" name="YOLOModDialogBase">
  <property name="geometry">
   <rect>
    <x>0</x>
    <y>0</y>
    <width>500</width>
    <height>500</height>
   </rect>
  </property>
  <property name="windowTitle">
   <string>YOLO-MOD</string>
  </property>
  <layout class="QVBoxLayout" name="mainVerticalLayout">
   <item>
    <widget class="QTabWidget" name="tabWidget">
     <property name="currentIndex">
      <number>0</number>
     </property>
     <widget class="QWidget" name="tab_detection">
      <attribute name="title">
       <string>Detection</string>
      </attribute>
      <layout class="QVBoxLayout" name="verticalLayout_detection">
       <item>
        <widget class="QTabWidget" name="tabWidget_models">
         <widget class="QWidget" name="tab_standard_models">
          <attribute name="title">
           <string>Standard Models</string>
          </attribute>
          <layout class="QVBoxLayout" name="verticalLayout_standard">
           <item>
            <layout class="QGridLayout" name="gridLayout_standard">
             <item row="0" column="0">
              <widget class="QLabel" name="label_model1">
               <property name="text">
                <string>Select model (.pt, .onnx):</string>
               </property>
              </widget>
             </item>
             <item row="0" column="1">
              <layout class="QHBoxLayout" name="horizontalLayout_model1">
               <item><widget class="QLineEdit" name="lineEdit_model1"/></item>
               <item><widget class="QToolButton" name="toolButton_model1"><property name="text"><string>...</string></property></widget></item>
              </layout>
             </item>
             <item row="1" column="0">
              <widget class="QLabel" name="label_multiple_models">
               <property name="text"><string>Multiple models:</string></property>
              </widget>
             </item>
             <item row="1" column="1">
              <widget class="QCheckBox" name="checkBox_run_multiple">
               <property name="text"><string>Run multiple models</string></property>
              </widget>
             </item>
             <item row="2" column="0">
              <widget class="QLabel" name="label_model2">
               <property name="text"><string>Select second model (.pt, .onnx):</string></property>
              </widget>
             </item>
             <item row="2" column="1">
              <layout class="QHBoxLayout" name="horizontalLayout_model2">
               <item><widget class="QLineEdit" name="lineEdit_model2"><property name="enabled"><bool>false</bool></property></widget></item>
               <item><widget class="QToolButton" name="toolButton_model2"><property name="enabled"><bool>false</bool></property><property name="text"><string>...</string></property></widget></item>
              </layout>
             </item>
             <item row="3" column="0" colspan="2">
              <layout class="QVBoxLayout" name="verticalLayout_colors_standard">
              </layout>
             </item>
            </layout>
           </item>
          </layout>
         </widget>
         <widget class="QWidget" name="tab_custom_model">
          <attribute name="title">
           <string>Custom Model</string>
          </attribute>
          <layout class="QVBoxLayout" name="verticalLayout_custom">
           <item>
            <layout class="QGridLayout" name="gridLayout_custom">
             <item row="0" column="0">
              <widget class="QLabel" name="label_custom_model">
               <property name="text">
                <string>Upload model (.pt):</string>
               </property>
              </widget>
             </item>
             <item row="0" column="1">
              <layout class="QHBoxLayout" name="horizontalLayout_custom_model">
               <item><widget class="QLineEdit" name="lineEdit_custom_model"/></item>
               <item><widget class="QToolButton" name="toolButton_custom_model"><property name="text"><string>...</string></property></widget></item>
              </layout>
             </item>
             <item row="1" column="0" colspan="2">
              <widget class="QLabel" name="label_custom_info">
               <property name="text">
                <string>Note: Custom model must be a YOLO (Ultralytics) model.
Classes will be loaded dynamically from the .pt file.</string>
               </property>
               <property name="styleSheet">
                <string>color: #d35400; font-weight: bold;</string>
               </property>
              </widget>
             </item>
             <item row="2" column="0" colspan="2">
              <widget class="QScrollArea" name="scrollArea_custom_colors">
               <property name="widgetResizable"><bool>true</bool></property>
               <widget class="QWidget" name="scrollAreaWidgetContents_custom">
                <layout class="QVBoxLayout" name="verticalLayout_colors_custom">
                </layout>
               </widget>
              </widget>
             </item>
            </layout>
           </item>
          </layout>
         </widget>
        </widget>
       </item>
       <item>
        <layout class="QGridLayout" name="gridLayout_shared_bottom">
         <property name="verticalSpacing"><number>6</number></property>
         <item row="0" column="0">
          <widget class="QLabel" name="label_layer">
           <property name="text">
            <string>Select a layer:</string>
           </property>
          </widget>
         </item>
         <item row="0" column="1">
          <widget class="QComboBox" name="comboBox"/>
         </item>
         <item row="1" column="0">
          <widget class="QLabel" name="label_target_option">
           <property name="text">
            <string>Save detections to:</string>
           </property>
          </widget>
         </item>
         <item row="1" column="1">
          <layout class="QVBoxLayout" name="verticalLayout_target">
           <item>
            <widget class="QRadioButton" name="radio_new_layer">
             <property name="text"><string>Create a new layer</string></property>
             <property name="checked"><bool>true</bool></property>
            </widget>
           </item>
           <item>
            <layout class="QHBoxLayout" name="horizontalLayout_append">
             <item>
              <widget class="QRadioButton" name="radio_append_layer">
               <property name="text"><string>Append to existing layer:</string></property>
              </widget>
             </item>
             <item>
              <widget class="QComboBox" name="comboBox_target_layer">
               <property name="enabled"><bool>false</bool></property>
              </widget>
             </item>
            </layout>
           </item>
          </layout>
         </item>
         <item row="2" column="0">
          <widget class="QLabel" name="label_confidence">
           <property name="text">
            <string>Confidence threshold (0–1):</string>
           </property>
          </widget>
         </item>
         <item row="2" column="1">
          <widget class="QDoubleSpinBox" name="spinBox_confidence">
           <property name="maximum"><double>1.0</double></property>
           <property name="singleStep"><double>0.05</double></property>
           <property name="value"><double>0.5</double></property>
          </widget>
         </item>
         <item row="3" column="0">
          <widget class="QLabel" name="label_fill">
           <property name="text"><string>Fill rectangles:</string></property>
          </widget>
         </item>
         <item row="3" column="1">
          <widget class="QCheckBox" name="checkBox_fill">
           <property name="text"><string>Use filled rectangles</string></property>
          </widget>
         </item>
         <item row="4" column="0">
          <widget class="QLabel" name="label__fill_transparency">
           <property name="text"><string>Fill transparency (0-100%):</string></property>
          </widget>
         </item>
         <item row="4" column="1">
          <widget class="QSpinBox" name="spinBox_fill_transparency">
           <property name="suffix"><string>%</string></property>
           <property name="maximum"><number>100</number></property>
          </widget>
         </item>
         <item row="5" column="0">
          <widget class="QLabel" name="label_outline_transparency">
           <property name="text"><string>Outline transparency (0-100%):</string></property>
          </widget>
         </item>
         <item row="5" column="1">
          <widget class="QSpinBox" name="spinBox_outline_transparency">
           <property name="suffix"><string>%</string></property>
           <property name="maximum"><number>100</number></property>
          </widget>
         </item>
        </layout>
       </item>
       <item>
        <spacer name="verticalSpacer_detect">
         <property name="orientation">
          <enum>Qt::Vertical</enum>
         </property>
         <property name="sizeHint" stdset="0">
          <size>
           <width>20</width>
           <height>40</height>
          </size>
         </property>
        </spacer>
       </item>
       <item>
        <layout class="QHBoxLayout" name="horizontalLayout_detect_buttons">
         <item>
          <spacer name="horizontalSpacer_detect">
           <property name="orientation">
            <enum>Qt::Horizontal</enum>
           </property>
          </spacer>
         </item>
         <item>
          <widget class="QPushButton" name="btn_detect_ok">
           <property name="text">
            <string>OK</string>
           </property>
          </widget>
         </item>
         <item>
          <widget class="QPushButton" name="btn_detect_cancel">
           <property name="text">
            <string>Cancel</string>
           </property>
          </widget>
         </item>
        </layout>
       </item>
      </layout>
     </widget>
     <widget class="QWidget" name="tab_edit">
      <attribute name="title">
        <string>Edit Detections</string>
      </attribute>
      <layout class="QVBoxLayout" name="verticalLayout_edit">
        <item>
          <widget class="QGroupBox" name="groupBox_merge">
            <property name="title">
              <string>Merge Layers</string>
            </property>
            <layout class="QVBoxLayout" name="verticalLayout_merge_group">
              <item>
                <layout class="QGridLayout" name="gridLayout_merge">
                  <item row="0" column="0">
                    <widget class="QLabel" name="label_merge_from">
                      <property name="text">
                        <string>Source Layer:</string>
                      </property>
                    </widget>
                  </item>
                  <item row="0" column="1">
                    <widget class="QComboBox" name="comboBox_merge_from"/>
                  </item>
                  <item row="1" column="0">
                    <widget class="QLabel" name="label_merge_to">
                      <property name="text">
                        <string>Destination Layer:</string>
                      </property>
                    </widget>
                  </item>
                  <item row="1" column="1">
                    <widget class="QComboBox" name="comboBox_merge_to"/>
                  </item>
                </layout>
              </item>
              <item>
                <layout class="QHBoxLayout" name="horizontalLayout_merge_btn">
                  <item>
                    <spacer name="horizontalSpacer_merge">
                      <property name="orientation">
                        <enum>Qt::Horizontal</enum>
                      </property>
                    </spacer>
                  </item>
                  <item>
                    <widget class="QPushButton" name="btn_merge_run">
                      <property name="text">
                        <string>Merge All Features</string>
                      </property>
                    </widget>
                  </item>
                </layout>
              </item>
            </layout>
          </widget>
        </item>
        <item>
          <widget class="QGroupBox" name="groupBox_selection_edit">
            <property name="title">
              <string>Selection Editing</string>
            </property>
            <layout class="QVBoxLayout" name="verticalLayout_selection_group">
              <item>
                <widget class="QLabel" name="label_selection_info">
                  <property name="text">
                    <string>No features selected on the map canvas.</string>
                  </property>
                  <property name="wordWrap">
                    <bool>true</bool>
                  </property>
                </widget>
              </item>
              <item>
                <layout class="QHBoxLayout" name="horizontalLayout_selection_btns">
                  <item>
                    <spacer name="horizontalSpacer_delete">
                      <property name="orientation">
                        <enum>Qt::Horizontal</enum>
                      </property>
                    </spacer>
                  </item>
                  <item>
                    <widget class="QPushButton" name="btn_delete_selected">
                      <property name="text">
                        <string>Delete Selected Features</string>
                      </property>
                      <property name="toolTip">
                        <string>Delete features currently selected in QGIS from their respective layer.</string>
                      </property>
                    </widget>
                  </item>
                </layout>
              </item>
            </layout>
          </widget>
        </item>
        <item>
          <spacer name="verticalSpacer_edit">
            <property name="orientation">
              <enum>Qt::Vertical</enum>
            </property>
            <property name="sizeHint" stdset="0">
              <size>
                <width>20</width>
                <height>40</height>
              </size>
            </property>
          </spacer>
        </item>
        <item>
          <layout class="QHBoxLayout" name="horizontalLayout_edit_cancel">
            <item>
              <spacer name="horizontalSpacer_edit_cancel">
                <property name="orientation">
                  <enum>Qt::Horizontal</enum>
                </property>
              </spacer>
            </item>
            <item>
              <widget class="QPushButton" name="btn_edit_close">
                <property name="text">
                  <string>Close</string>
                </property>
              </widget>
            </item>
          </layout>
        </item>
      </layout>
    </widget>
     <widget class="QWidget" name="tab_export">
      <attribute name="title">
       <string>Export Results</string>
      </attribute>
      <layout class="QVBoxLayout" name="verticalLayout_export">
       <item>
        <layout class="QGridLayout" name="gridLayout_export">
         <item row="0" column="0">
          <widget class="QLabel" name="label_export_dir">
           <property name="text">
            <string>Save to directory:</string>
           </property>
          </widget>
         </item>
         <item row="0" column="1">
          <layout class="QHBoxLayout" name="horizontalLayout_export_dir">
           <item>
            <widget class="QLineEdit" name="lineEdit_export_dir"/>
           </item>
           <item>
            <widget class="QToolButton" name="toolButton_export_dir">
             <property name="text">
              <string>...</string>
             </property>
            </widget>
           </item>
          </layout>
         </item>
        <item row="1" column="0">
          <widget class="QLabel" name="label_options">
           <property name="text">
            <string>Options:</string>
           </property>
          </widget>
         </item>
         <item row="2" column="0">
          <widget class="QLabel" name="label_export_layer">
           <property name="text">
            <string>Export detections from:</string>
           </property>
          </widget>
         </item>
         <item row="2" column="1">
          <widget class="QComboBox" name="comboBox_export_layer"/>
         </item>
         <item row="1" column="1">
          <layout class="QVBoxLayout" name="verticalLayout_export_options">
           <item>
            <widget class="QCheckBox" name="checkBox_save_canvas">
             <property name="text">
              <string>Save current canvas as image</string>
             </property>
            </widget>
           </item>
           <item>
            <widget class="QCheckBox" name="checkBox_save_yolo">
             <property name="text">
              <string>Save detections as YOLO format</string>
             </property>
            </widget>
           </item>
          </layout>
         </item>
        </layout>
       </item>
       <item>
        <spacer name="verticalSpacer_export">
         <property name="orientation">
          <enum>Qt::Vertical</enum>
         </property>
         <property name="sizeHint" stdset="0">
          <size>
           <width>20</width>
           <height>40</height>
          </size>
         </property>
        </spacer>
       </item>
       <item>
        <layout class="QHBoxLayout" name="horizontalLayout_export_buttons">
         <item>
          <spacer name="horizontalSpacer_export">
           <property name="orientation">
            <enum>Qt::Horizontal</enum>
           </property>
          </spacer>
         </item>
         <item>
          <widget class="QPushButton" name="btn_export_save">
           <property name="text">
            <string>Save</string>
           </property>
          </widget>
         </item>
         <item>
          <widget class="QPushButton" name="btn_export_cancel">
           <property name="text">
            <string>Cancel</string>
           </property>
          </widget>
         </item>
        </layout>
       </item>
      </layout>
     </widget>
     <widget class="QWidget" name="tab_preview">
      <attribute name="title"><string>Preview Export</string></attribute>
      <layout class="QVBoxLayout" name="verticalLayout_preview">
        <item>
        <layout class="QGridLayout" name="gridLayout_preview">
          <property name="verticalSpacing"><number>6</number></property>
          <item row="0" column="0"><widget class="QLabel"><property name="text"><string>Select Image:</string></property></widget></item>
          <item row="0" column="1">
          <layout class="QHBoxLayout">
            <item><widget class="QLineEdit" name="lineEdit_preview_img"/></item>
            <item><widget class="QToolButton" name="toolButton_preview_img"><property name="text"><string>...</string></property></widget></item>
          </layout>
          </item>
          <item row="1" column="0"><widget class="QLabel"><property name="text"><string>Select YOLO labels:</string></property></widget></item>
          <item row="1" column="1">
          <layout class="QHBoxLayout">
            <item><widget class="QLineEdit" name="lineEdit_preview_txt"/></item>
            <item><widget class="QToolButton" name="toolButton_preview_txt"><property name="text"><string>...</string></property></widget></item>
          </layout>
          </item>
        </layout>
        </item>
        <item>
        <spacer name="vSpacer_preview">
          <property name="orientation"><enum>Qt::Vertical</enum></property>
          <property name="sizeHint" stdset="0">
          <size><width>20</width><height>40</height></size>
          </property>
        </spacer>
        </item>
        <item>
        <layout class="QHBoxLayout" name="horizontalLayout_preview_buttons">
          <item><spacer name="hSpacer_preview"><property name="orientation"><enum>Qt::Horizontal</enum></property></spacer></item>
          <item><widget class="QPushButton" name="btn_preview_run"><property name="text"><string>Preview</string></property></widget></item>
          <item><widget class="QPushButton" name="btn_preview_cancel"><property name="text"><string>Cancel</string></property></widget></item>
        </layout>
        </item>
      </layout>
     </widget>
     <widget class="QWidget" name="tab_tiling">
      <attribute name="title">
        <string>Canvas Tiling</string>
      </attribute>
      <layout class="QVBoxLayout" name="verticalLayout_tiling">
        <item>
        <layout class="QGridLayout" name="gridLayout_tiling">
          <property name="verticalSpacing">
          <number>6</number>
          </property>
          <item row="0" column="0">
          <widget class="QLabel" name="label_canvas_res">
            <property name="text"><string>Canvas Resolution:</string></property>
          </widget>
          </item>
          <item row="0" column="1">
          <widget class="QLabel" name="label_canvas_res_value">
            <property name="text"><string>0 x 0 px</string></property>
          </widget>
          </item>
          <item row="1" column="0">
          <widget class="QLabel">
            <property name="text"><string>Tile Width (px):</string></property>
          </widget>
          </item>
          <item row="1" column="1">
          <widget class="QSpinBox" name="spinBox_tile_width">
            <property name="maximum"><number>5000</number></property>
            <property name="value"><number>128</number></property>
          </widget>
          </item>
          <item row="2" column="0">
          <widget class="QLabel">
            <property name="text"><string>Tile Height (px):</string></property>
          </widget>
          </item>
          <item row="2" column="1">
          <widget class="QSpinBox" name="spinBox_tile_height">
            <property name="maximum"><number>5000</number></property>
            <property name="value"><number>128</number></property>
          </widget>
          </item>
          <item row="3" column="0">
          <widget class="QLabel">
            <property name="text"><string>Tile Overlap (%):</string></property>
          </widget>
          </item>
          <item row="3" column="1">
          <widget class="QSpinBox" name="spinBox_tile_overlap">
            <property name="maximum"><number>99</number></property>
            <property name="value"><number>0</number></property>
          </widget>
          </item>
          <item row="4" column="0">
          <widget class="QLabel">
            <property name="text"><string>Save to:</string></property>
          </widget>
          </item>
          <item row="4" column="1">
          <layout class="QHBoxLayout">
            <item><widget class="QLineEdit" name="lineEdit_tiling_dir"/></item>
            <item>
            <widget class="QToolButton" name="toolButton_tiling_dir">
              <property name="text"><string>...</string></property>
            </widget>
            </item>
          </layout>
          </item>
        </layout>
        </item>
        <item>
        <spacer name="verticalSpacer_tiling">
          <property name="orientation"><enum>Qt::Vertical</enum></property>
          <property name="sizeHint" stdset="0">
          <size><width>20</width><height>40</height></size>
          </property>
        </spacer>
        </item>
        <item>
        <layout class="QHBoxLayout" name="horizontalLayout_tiling_buttons">
          <item>
          <spacer name="hSpacer_tiling">
            <property name="orientation"><enum>Qt::Horizontal</enum></property>
          </spacer>
          </item>
          <item>
          <widget class="QPushButton" name="btn_tiling_run">
            <property name="text"><string>Preview and Start Tiling</string></property>
          </widget>
          </item>
          <item>
          <widget class="QPushButton" name="btn_tiling_cancel">
            <property name="text"><string>Cancel</string></property>
          </widget>
          </item>
        </layout>
        </item>
      </layout>
     </widget>
    </widget>
   </item>
  </layout>
 </widget>
</ui>